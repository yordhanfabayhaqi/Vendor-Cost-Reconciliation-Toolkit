// ============================================================
// CONFIG LAYER — Script Properties reader / writer
// Used everywhere in the codebase that needs runtime config.
// ============================================================

/**
 * Read a runtime config value from Script Properties.
 * Throws if the key hasn't been set via the ⚙️ Setup menu.
 * 
 * @param {string} propKey  One of the CONFIG.PROP_* constants
 * @param {boolean} [required=true]  If false, returns null when unset instead of throwing
 * @return {string|null}
 */
function getConfig_(propKey, required) {
  if (required === undefined) required = true;
  const value = PropertiesService.getScriptProperties().getProperty(propKey);
  if (!value && required) {
    throw new Error(
      'Missing config: "' + propKey + '". ' +
      'Open the ⚙️ Setup menu and configure this value.'
    );
  }
  return value || null;
}

/**
 * Persist a runtime config value to Script Properties.
 * 
 * @param {string} propKey
 * @param {string} value
 */
function saveConfig_(propKey, value) {
  if (!propKey) throw new Error('saveConfig_: propKey required');
  PropertiesService.getScriptProperties().setProperty(propKey, String(value || ''));
}

/**
 * Menu-driven Setup UI. Prompts for each configurable value one by one.
 * Existing values are shown so the user can confirm or overwrite.
 */
function menu_setup() {
  const ui = SpreadsheetApp.getUi();
  const items = [
    { key: CONFIG.PROP_LLM_API_KEY,           label: 'LLM API key' },
    { key: CONFIG.PROP_EMAIL_RECIPIENTS,      label: 'Notification email recipient(s), comma-separated' },
    { key: CONFIG.PROP_EMAIL_FROM_NAME,       label: 'Sender display name for notifications' },
    { key: CONFIG.PROP_PARENT_FOLDER_ID,      label: 'Parent Drive folder ID (where inbox/archive live)' }
  ];

  for (const item of items) {
    const current = PropertiesService.getScriptProperties().getProperty(item.key) || '(not set)';
    const response = ui.prompt(
      '⚙️ Setup: ' + item.label,
      'Current value: ' + (item.key === CONFIG.PROP_LLM_API_KEY ? maskSecret_(current) : current) +
        '\n\nEnter new value, or leave blank to keep current:',
      ui.ButtonSet.OK_CANCEL
    );
    if (response.getSelectedButton() !== ui.Button.OK) {
      ui.alert('Setup cancelled. Any changes so far are already saved.');
      return;
    }
    const val = response.getResponseText().trim();
    if (val) saveConfig_(item.key, val);
  }

  ui.alert(
    '⚙️ Setup complete',
    'Runtime config saved to Script Properties.\n\n' +
    'Next: run the folder-setup and master-sheet-init commands from the menu ' +
    'to provision the workspace.',
    ui.ButtonSet.OK
  );
}

function maskSecret_(value) {
  if (!value || value === '(not set)') return value;
  if (value.length <= 8) return '••••';
  return value.substring(0, 4) + '••••' + value.substring(value.length - 4);
}

/**
 * Attaches a top-level ⚙️ Setup menu. If your project already has an onOpen()
 * for other menus, merge this into it (don't declare two onOpen functions).
 */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('⚙️ Setup')
    .addItem('Configure keys, IDs, and recipients', 'menu_setup')
    .addToUi();
}
